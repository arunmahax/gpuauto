# Environment Configuration
# Copy this to .env and fill in your API keys

# OpenAI API Key (for transcript summarization and script expansion)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI TTS model (tts-1 or tts-1-hd)
TTS_MODEL=tts-1

# TTS Voice (alloy, echo, fable, onyx, nova, shimmer)
TTS_VOICE=onyx

# LLM model for narrative generation
LLM_MODEL=gpt-4o

# FFmpeg path (leave empty to use system PATH)
FFMPEG_PATH=

# Scene detection threshold (0.0 to 1.0, lower = more sensitive)
SCENE_THRESHOLD=0.3

# Output video settings
OUTPUT_FPS=30
OUTPUT_WIDTH=1920
OUTPUT_HEIGHT=1080

# Remotion concurrency
RENDER_CONCURRENCY=50%
